# OpenAI API key used by the serverless route (api/parse.js) to power the
# natural-language invoice wizard. Get one at https://platform.openai.com/api-keys
#
# This is a SERVER-SIDE secret. Never expose it with a VITE_ prefix — anything
# prefixed with VITE_ is bundled into the public client build.
OPENAI_API_KEY=sk-...

# Optional: override the model used for parsing (defaults to gpt-4o-mini).
# OPENAI_MODEL=gpt-4o-mini
